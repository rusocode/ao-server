# Forzar normalizacion de texto a LF para consistencia entre OS
* text=auto eol=lf

# Archivos Java y de configuracion como texto
*.java text
*.ini text
*.dat text
*.inf text
*.properties text
*.xml text
*.md text

# ARCHIVOS BINARIOS (CRITICO - No tocar finales de linea)
*.map binary
*.png binary
*.jpg binary
*.ico binary
*.jar binary
